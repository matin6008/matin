# Copy this file to ".env" and fill in the values from your Supabase project.
# Supabase dashboard → Project Settings → API

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# service_role key (secret). Server-side only — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket that holds carpet photos (created by `npm run setup`).
SUPABASE_BUCKET=carpets

# Optional: initial admin password used the first time the DB is seeded.
ADMIN_PASSWORD=mohtasham1401

PORT=3000
